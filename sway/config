# ~/.config/sway/config
# SwayFX + Catppuccin Mocha (accent Yellow)

###############################################################################
# VARIABLES
###############################################################################

set $mod Mod4

set $term      foot
set $menu      wofi --show drun
set $lock      swaylock -f -c 1e1e2e
set $browser   firefox

# Catppuccin Mocha -- unique point d'édition pour changer de palette
set $base      #1a1a1a
set $mantle    #0f0f0f
set $crust     #000000
set $text      #cdd6f4
set $subtext1  #bac2de
set $surface0  #2a2a2a
set $surface1  #3a3a3a
set $surface2  #585b70
set $overlay0  #6c7086
set $accent    #f9e2af
set $red       #f38ba8

###############################################################################
# APPARENCE
###############################################################################

font pango:JetBrainsMono Nerd Font 11

default_border pixel 2
default_floating_border pixel 2
titlebar_border_thickness 0
titlebar_padding 1 1
smart_borders on
smart_gaps on
gaps inner 8
gaps outer 4

# class                 border     bg         text      indicator  child_border
client.focused          $accent    $accent    $crust    $accent    $accent
client.focused_inactive $surface1  $surface1  $text     $surface1  $surface1
client.unfocused        $surface0  $surface0  $subtext1 $surface0  $surface0
client.urgent           $red       $red       $crust    $red       $red
client.placeholder      $mantle    $mantle    $text     $mantle    $mantle
client.background       $base

output * bg $base solid_color

# ---- Outputs desktop (mode Bureau par défaut) ----
output DP-1 {
    mode 2560x1440@143.972Hz
    position 0 240
    scale 1.0
}
output HDMI-A-1 {
    mode 1920x1080@60.000Hz
    position 2560 0
    transform 90
    scale 1.0
}


# ---- Outputs desktop (mode Bureau par défaut) ----
output DP-1 {
    mode 2560x1440@143.972Hz
    position 0 240
    scale 1.0
}
output HDMI-A-1 {
    mode 1920x1080@60.000Hz
    position 2560 0
    transform 90
    scale 1.0
}


###############################################################################
# EFFETS SwayFX
###############################################################################

blur enable
blur_passes 3
blur_radius 5

corner_radius 10
smart_corner_radius on

shadows enable
shadows_on_csd disable
shadow_blur_radius 20
shadow_color #00000099
shadow_offset 0 5

layer_effects "waybar" blur enable; blur_ignore_transparent enable; shadows enable; corner_radius 10

###############################################################################
# SAISIE
###############################################################################



###############################################################################
# AUTOSTART
###############################################################################

exec_always dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway

# Agent polkit (remplace polkit-gnome retiré de Fedora 41+)
exec lxpolkit

exec mako
exec --no-startup-id swaymsg input type:keyboard xkb_numlock enabled
exec --no-startup-id swaymsg input type:keyboard xkb_numlock enabled

exec_always systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP
exec_always systemctl --user restart xdg-desktop-portal-wlr.service

###############################################################################
# KEYBINDS
###############################################################################

bindsym --to-code $mod+Return     exec $term
bindsym --to-code $mod+d          exec $menu
bindsym --to-code $mod+Shift+q    kill
bindsym --to-code $mod+Shift+c    reload
bindsym --to-code $mod+Shift+e    exec swaynag -t warning \
    -m 'Quitter la session Sway ?' \
    -B 'Oui' 'swaymsg exit'

floating_modifier $mod normal

bindsym --to-code $mod+Left       focus left
bindsym --to-code $mod+Down       focus down
bindsym --to-code $mod+Up         focus up
bindsym --to-code $mod+Right      focus right
bindsym --to-code $mod+h          focus left
bindsym --to-code $mod+j          focus down
bindsym --to-code $mod+k          focus up
bindsym --to-code $mod+l          focus right

bindsym --to-code $mod+Shift+Left    move left
bindsym --to-code $mod+Shift+Down    move down
bindsym --to-code $mod+Shift+Up      move up
bindsym --to-code $mod+Shift+Right   move right
bindsym --to-code $mod+Shift+h       move left
bindsym --to-code $mod+Shift+j       move down
bindsym --to-code $mod+Shift+k       move up
bindsym --to-code $mod+Shift+l       move right

bindsym $mod+ampersand workspace number 1
bindsym $mod+eacute workspace number 2
bindsym $mod+quotedbl workspace number 3
bindsym $mod+apostrophe workspace number 4
bindsym $mod+parenleft workspace number 5
bindsym $mod+minus workspace number 6
bindsym $mod+egrave workspace number 7
bindsym $mod+underscore workspace number 8
bindsym $mod+ccedilla workspace number 9
bindsym $mod+0 workspace number 10

bindsym $mod+Shift+ampersand move container to workspace number 1
bindsym $mod+Shift+eacute move container to workspace number 2
bindsym $mod+Shift+quotedbl move container to workspace number 3
bindsym $mod+Shift+apostrophe move container to workspace number 4
bindsym $mod+Shift+parenleft move container to workspace number 5
bindsym $mod+Shift+minus move container to workspace number 6
bindsym $mod+Shift+egrave move container to workspace number 7
bindsym $mod+Shift+underscore move container to workspace number 8
bindsym $mod+Shift+ccedilla move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

bindsym --to-code $mod+b          splith
bindsym --to-code $mod+v          splitv
bindsym --to-code $mod+s          layout stacking
bindsym --to-code $mod+w          layout tabbed
bindsym --to-code $mod+e          layout toggle split
bindsym --to-code $mod+Ctrl+e     exec foot -a yazi-files -c ~/.config/foot/yazi.ini yazi
bindsym --to-code $mod+f          fullscreen
bindsym --to-code $mod+Shift+space floating toggle
bindsym --to-code $mod+space      focus mode_toggle
bindsym --to-code $mod+a          focus parent

bindsym $mod+Shift+less move scratchpad
bindsym $mod+less scratchpad show

mode "resize" {
    bindsym --to-code Left     resize shrink width 10px
    bindsym --to-code Down     resize grow   height 10px
    bindsym --to-code Up       resize shrink height 10px
    bindsym --to-code Right    resize grow   width 10px
    bindsym --to-code h        resize shrink width 10px
    bindsym --to-code j        resize grow   height 10px
    bindsym --to-code k        resize shrink height 10px
    bindsym --to-code l        resize grow   width 10px
    bindsym --to-code Return   mode "default"
    bindsym --to-code Escape   mode "default"
}
bindsym --to-code $mod+r mode "resize"

bindsym --to-code Print            exec grim - | wl-copy
bindsym --to-code Shift+Print      exec slurp | grim -g - - | wl-copy
bindsym --to-code Ctrl+Print       exec grim ~/Pictures/screenshot-$(date +%F-%H%M%S).png
bindsym --to-code Ctrl+Shift+Print exec slurp | grim -g - ~/Pictures/screenshot-$(date +%F-%H%M%S).png

bindsym --to-code --locked XF86AudioRaiseVolume  exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym --to-code --locked XF86AudioLowerVolume  exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym --to-code --locked XF86AudioMute         exec wpctl set-mute   @DEFAULT_AUDIO_SINK@ toggle
bindsym --to-code --locked XF86AudioMicMute      exec wpctl set-mute   @DEFAULT_AUDIO_SOURCE@ toggle
bindsym --to-code --locked XF86AudioPlay         exec playerctl play-pause
bindsym --to-code --locked XF86AudioNext         exec playerctl next
bindsym --to-code --locked XF86AudioPrev         exec playerctl previous
bindsym --to-code --locked XF86MonBrightnessUp   exec brightnessctl set +5%
bindsym --to-code --locked XF86MonBrightnessDown exec brightnessctl set 5%-

# bindsym $mod+Escape exec $lock

###############################################################################
# RÈGLES DE FENÊTRE
###############################################################################

for_window [app_id="pavucontrol"]      floating enable, resize set 600 500
for_window [app_id="nm-connection-editor"] floating enable
for_window [app_id="foot" title="^float-.*"] floating enable
for_window [title="Picture-in-Picture"] floating enable, sticky enable

bar {
    swaybar_command waybar
}

include /etc/sway/config.d/*

input "type:keyboard" {
    xkb_layout fr
    xkb_variant oss
    xkb_numlock enable
    repeat_delay 250
    repeat_rate 40
}

# ---- Assignation workspaces aux outputs ----
workspace 1 output DP-1
workspace 2 output DP-1
workspace 3 output DP-1
workspace 4 output DP-1
workspace 5 output DP-1
workspace 6 output HDMI-A-1
workspace 7 output HDMI-A-1
workspace 8 output HDMI-A-1
workspace 9 output HDMI-A-1
workspace 10 output HDMI-A-1
