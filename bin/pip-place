#!/usr/bin/env bash
set -euo pipefail

output="DP-1"
pip_w=640
pip_h=360
margin=24

title_re="Picture-in-Picture|Picture in picture|Picture-in-picture|Image dans l.?image"

pip_id="$(
    swaymsg -t get_tree | jq -r --arg re "$title_re" '
        [
            recurse(.nodes[]?, .floating_nodes[]?)
            | select((.name // "") | test($re; "i"))
            | .id
        ] | last // empty
    '
)"

[[ -n "$pip_id" ]] || exit 0

# Mettre le PiP sur DP-1 et le rendre flottant/sticky.
swaymsg "[con_id=${pip_id}] floating enable, sticky enable, border pixel 1" >/dev/null
swaymsg "[con_id=${pip_id}] move container to output ${output}" >/dev/null || true
swaymsg "[con_id=${pip_id}] resize set width ${pip_w} px height ${pip_h} px" >/dev/null

sleep 0.05

# IMPORTANT :
# move position x y est relatif à la zone utile du workspace,
# pas aux coordonnées globales de l'écran.
read wx wy ww wh < <(
    swaymsg -t get_workspaces | jq -r --arg out "$output" '
        map(select(.visible and .output == $out))[0] as $w
        | "\($w.rect.x) \($w.rect.y) \($w.rect.width) \($w.rect.height)"
    '
)

[[ -n "${ww:-}" && "$ww" != "null" ]] || exit 0

x=$((ww - pip_w - margin))
y=$((wh - pip_h - margin))

(( x < 0 )) && x=0
(( y < 0 )) && y=0

swaymsg "[con_id=${pip_id}] move position ${x} ${y}" >/dev/null
