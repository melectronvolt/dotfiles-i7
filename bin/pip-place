#!/usr/bin/env bash
set -euo pipefail

output="DP-1"
pip_w=640
pip_h=360
margin=24

title_re="Picture-in-Picture|Picture in picture|Picture-in-picture|Image dans l.?image"

pip_id="$(
    swaymsg -t get_tree | jq -r --arg re "$title_re" '
        [
            recurse(.nodes[]?, .floating_nodes[]?)
            | select((.name // "") | test($re; "i"))
            | .id
        ] | last // empty
    '
)"

[[ -n "$pip_id" ]] || exit 0

read ox oy ow oh < <(
    swaymsg -t get_outputs | jq -r --arg out "$output" '
        map(select(.active and .name == $out))[0] as $o
        | "\($o.rect.x) \($o.rect.y) \($o.rect.width) \($o.rect.height)"
    '
)

[[ -n "${ox:-}" && "$ox" != "null" ]] || exit 0

x=$((ox + ow - pip_w - margin))
y=$((oy + oh - pip_h - margin))

# Deux passes : le move-to-output peut recentrer/replacer la fenêtre.
swaymsg "[con_id=${pip_id}] move container to output ${output}" >/dev/null
sleep 0.05

swaymsg "[con_id=${pip_id}] floating enable, sticky enable, border pixel 1, resize set width ${pip_w} px height ${pip_h} px" >/dev/null
sleep 0.05

swaymsg "[con_id=${pip_id}] move absolute position ${x} px ${y} px" >/dev/null
